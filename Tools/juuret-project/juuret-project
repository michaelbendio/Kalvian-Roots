#!/usr/bin/env zsh
set -euo pipefail

usage() {
  cat >&2 <<'USAGE'
Usage:
  juuret-project workup FAMILY_ID [--host http://127.0.0.1:8081]
  juuret-project source FAMILY_ID [--host http://127.0.0.1:8081]
  juuret-project summary FAMILY_ID [--host http://127.0.0.1:8081]
  juuret-project actions FAMILY_ID [--host http://127.0.0.1:8081]
  juuret-project next FAMILY_ID [--host http://127.0.0.1:8081]
  juuret-project action FAMILY_ID ACTION_ID [--host http://127.0.0.1:8081]
  juuret-project proposal FAMILY_ID ACTION_ID [--host http://127.0.0.1:8081]
  juuret-project source-update-preview FAMILY_ID ACTION_ID [--host http://127.0.0.1:8081]
  juuret-project id-mismatch-preview FAMILY_ID ACTION_ID [--host http://127.0.0.1:8081]
  juuret-project source-edit-dry-run FAMILY_ID ACTION_ID [--host http://127.0.0.1:8081]
  juuret-project source-edit-apply FAMILY_ID ACTION_ID [--host http://127.0.0.1:8081]

Options:
  --host URL            Kalvian Roots server URL.
  --workup-json PATH    Read an already captured workup JSON file instead of calling the app.
  --source-text PATH    Read already captured source text for source-update-preview.
  --roots-file PATH     Roots file to edit for source-edit-apply.
  --type TYPE           Limit summary/actions/next to one action type.
  --kind KIND           Limit summary/actions/next to source-update or id-mismatch.

The Kalvian Roots macOS app must be running unless --workup-json is used.
USAGE
}

if [[ $# -lt 2 ]]; then
  usage
  exit 64
fi

command_name="$1"
shift

host="http://127.0.0.1:8081"
family_id=""
action_id=""
workup_json_path=""
source_text_path=""
roots_file_path="${HOME}/Documents/JuuretKälviällä.roots"
action_type=""
action_kind=""

case "$command_name" in
  workup|source|summary|actions|next)
    family_id="$1"
    shift
    ;;
  action|proposal|source-update-preview|id-mismatch-preview|source-edit-dry-run|source-edit-apply)
    if [[ $# -lt 2 ]]; then
      usage
      exit 64
    fi
    family_id="$1"
    action_id="$2"
    shift 2
    ;;
  *)
    usage
    exit 64
    ;;
esac

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      if [[ $# -lt 2 ]]; then
        usage
        exit 64
      fi
      host="$2"
      shift 2
      ;;
    --workup-json)
      if [[ $# -lt 2 ]]; then
        usage
        exit 64
      fi
      workup_json_path="$2"
      shift 2
      ;;
    --source-text)
      if [[ $# -lt 2 ]]; then
        usage
        exit 64
      fi
      source_text_path="$2"
      shift 2
      ;;
    --roots-file)
      if [[ $# -lt 2 ]]; then
        usage
        exit 64
      fi
      roots_file_path="$2"
      shift 2
      ;;
    --type)
      if [[ $# -lt 2 ]]; then
        usage
        exit 64
      fi
      action_type="$2"
      shift 2
      ;;
    --kind)
      if [[ $# -lt 2 ]]; then
        usage
        exit 64
      fi
      action_kind="$2"
      shift 2
      ;;
    *)
      usage
      exit 64
      ;;
  esac
done

encoded_family_id="$(
  python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "$family_id"
)"

if [[ "$command_name" == "source" ]]; then
  curl --fail --silent --show-error "$host/family/$encoded_family_id/source.txt"
  exit 0
fi

if [[ -n "$workup_json_path" ]]; then
  workup_json="$(< "$workup_json_path")"
else
  workup_json="$(curl --fail --silent --show-error "$host/family/$encoded_family_id/workup.json")"
fi

case "$command_name" in
  workup)
    print -r -- "$workup_json"
    ;;
  summary)
    if [[ -n "$action_type" ]]; then
      python3 "${0:A:h}/format_action.py" summary --type "$action_type" <<< "$workup_json"
    elif [[ -n "$action_kind" ]]; then
      python3 "${0:A:h}/format_action.py" summary --kind "$action_kind" <<< "$workup_json"
    else
      python3 "${0:A:h}/format_action.py" summary <<< "$workup_json"
    fi
    ;;
  actions)
    if [[ -n "$action_type" ]]; then
      python3 "${0:A:h}/format_action.py" actions --type "$action_type" <<< "$workup_json"
    elif [[ -n "$action_kind" ]]; then
      python3 "${0:A:h}/format_action.py" actions --kind "$action_kind" <<< "$workup_json"
    else
      python3 "${0:A:h}/format_action.py" actions <<< "$workup_json"
    fi
    ;;
  next)
    if [[ -n "$action_type" ]]; then
      python3 "${0:A:h}/format_action.py" next --type "$action_type" <<< "$workup_json"
    elif [[ -n "$action_kind" ]]; then
      python3 "${0:A:h}/format_action.py" next --kind "$action_kind" <<< "$workup_json"
    else
      python3 "${0:A:h}/format_action.py" next <<< "$workup_json"
    fi
    ;;
  action)
    python3 "${0:A:h}/format_action.py" action "$action_id" <<< "$workup_json"
    ;;
  proposal)
    python3 "${0:A:h}/format_action.py" proposal "$action_id" <<< "$workup_json"
    ;;
  source-update-preview)
    if [[ -n "$source_text_path" ]]; then
      python3 "${0:A:h}/format_action.py" proposal "$action_id" --source-text "$source_text_path" <<< "$workup_json"
    else
      fetched_source_text_path="$(mktemp)"
      trap 'rm -f "$fetched_source_text_path"' EXIT
      curl --fail --silent --show-error "$host/family/$encoded_family_id/source.txt" > "$fetched_source_text_path"
      python3 "${0:A:h}/format_action.py" proposal "$action_id" --source-text "$fetched_source_text_path" <<< "$workup_json"
    fi
    ;;
  id-mismatch-preview)
    if [[ -n "$source_text_path" ]]; then
      python3 "${0:A:h}/format_action.py" proposal "$action_id" --source-text "$source_text_path" --source-context id-mismatch <<< "$workup_json"
    else
      fetched_source_text_path="$(mktemp)"
      trap 'rm -f "$fetched_source_text_path"' EXIT
      curl --fail --silent --show-error "$host/family/$encoded_family_id/source.txt" > "$fetched_source_text_path"
      python3 "${0:A:h}/format_action.py" proposal "$action_id" --source-text "$fetched_source_text_path" --source-context id-mismatch <<< "$workup_json"
    fi
    ;;
  source-edit-dry-run)
    if [[ -n "$source_text_path" ]]; then
      python3 "${0:A:h}/format_action.py" proposal "$action_id" --source-text "$source_text_path" --source-edit-dry-run <<< "$workup_json"
    else
      fetched_source_text_path="$(mktemp)"
      trap 'rm -f "$fetched_source_text_path"' EXIT
      curl --fail --silent --show-error "$host/family/$encoded_family_id/source.txt" > "$fetched_source_text_path"
      python3 "${0:A:h}/format_action.py" proposal "$action_id" --source-text "$fetched_source_text_path" --source-edit-dry-run <<< "$workup_json"
    fi
    ;;
  source-edit-apply)
    if [[ ! -f "$roots_file_path" ]]; then
      print -u2 -- "Roots file not found: $roots_file_path"
      exit 66
    fi
    python3 "${0:A:h}/format_action.py" proposal "$action_id" --source-text "$roots_file_path" --source-edit-apply <<< "$workup_json"
    ;;
esac
