#!/usr/bin/env zsh
set -euo pipefail

usage() {
  cat >&2 <<'USAGE'
Usage:
  juuret-project workup FAMILY_ID [--host http://127.0.0.1:8081]

The Kalvian Roots macOS app must be running for this first slice.
USAGE
}

if [[ $# -lt 2 ]]; then
  usage
  exit 64
fi

command_name="$1"
shift

host="http://127.0.0.1:8081"
family_id=""

case "$command_name" in
  workup)
    family_id="$1"
    shift
    ;;
  *)
    usage
    exit 64
    ;;
esac

while [[ $# -gt 0 ]]; do
  case "$1" in
    --host)
      if [[ $# -lt 2 ]]; then
        usage
        exit 64
      fi
      host="$2"
      shift 2
      ;;
    *)
      usage
      exit 64
      ;;
  esac
done

encoded_family_id="$(
  python3 -c 'import sys, urllib.parse; print(urllib.parse.quote(sys.argv[1], safe=""))' "$family_id"
)"

curl --fail --silent --show-error "$host/family/$encoded_family_id/workup.json"
